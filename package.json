{
  "name": "ignore-panel",
  "displayName": "Ignore Panel",
  "description": "Shows Git ignored files and configured Explorer excludes in a dedicated Explorer pane.",
  "version": "1.0.0",
  "publisher": "armanio123",
  "license": "MIT",
  "author": "Armando Aguirre <armanio123@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/armanio123/ignore-panel.git"
  },
  "bugs": {
    "url": "https://github.com/armanio123/ignore-panel/issues"
  },
  "homepage": "https://github.com/armanio123/ignore-panel#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "resources/ignored-files.png",
  "keywords": [
    "gitignore",
    "ignore",
    "explorer",
    "files.exclude",
    "git"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ignorePanel.refresh",
        "title": "Ignore Panel: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "ignorePanel.openItem",
        "title": "Ignore Panel: Open",
        "icon": "$(go-to-file)"
      },
      {
        "command": "ignorePanel.toggleHiding",
        "title": "Ignore Panel: Toggle Hiding Ignored Files",
        "icon": "$(eye-closed)"
      },
      {
        "command": "ignorePanel.enableHiding",
        "title": "Ignore Panel: Toggle Hiding Ignored Files",
        "icon": "$(eye-closed)"
      },
      {
        "command": "ignorePanel.disableHiding",
        "title": "Ignore Panel: Toggle Hiding Ignored Files",
        "icon": "$(eye)"
      }
    ],
    "configuration": {
      "title": "Ignore Panel",
      "properties": {
        "ignorePanel.includeGitIgnored": {
          "type": "boolean",
          "default": true,
          "description": "Include files and folders reported by git ls-files --ignored --exclude-standard."
        },
        "ignorePanel.includeVSCodeExcludes": {
          "type": "boolean",
          "default": true,
          "description": "Include existing files.exclude patterns in the Ignored Files pane."
        },
        "ignorePanel.extraIgnoreFiles": {
          "type": "array",
          "default": [
            ".ignore",
            ".npmignore",
            ".dockerignore",
            ".eslintignore",
            ".prettierignore"
          ],
          "items": {
            "type": "string"
          },
          "description": "Workspace-relative ignore files to parse as additional ignore sources. Basic glob lines are supported."
        },
        "ignorePanel.settingsTarget": {
          "type": "string",
          "default": "workspace",
          "enum": [
            "workspace",
            "user"
          ],
          "enumDescriptions": [
            "Write explorer.excludeGitIgnore changes to workspace settings.",
            "Write explorer.excludeGitIgnore changes to user settings."
          ],
          "description": "Controls whether Ignore Panel writes explorer.excludeGitIgnore changes to workspace settings or user settings."
        },
        "ignorePanel.refreshIntervalSeconds": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Optional automatic refresh interval. Set to 0 to disable."
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "ignorePanel.openItem",
          "when": "false"
        },
        {
          "command": "ignorePanel.enableHiding",
          "when": "false"
        },
        {
          "command": "ignorePanel.disableHiding",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "ignorePanel.refresh",
          "when": "view == ignorePanel.ignoredFiles",
          "group": "navigation@1"
        },
        {
          "command": "ignorePanel.disableHiding",
          "when": "view == ignorePanel.ignoredFiles && config.explorer.excludeGitIgnore",
          "group": "navigation@2"
        },
        {
          "command": "ignorePanel.enableHiding",
          "when": "view == ignorePanel.ignoredFiles && !config.explorer.excludeGitIgnore",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "ignorePanel.openItem",
          "when": "view == ignorePanel.ignoredFiles && viewItem == ignoredFile",
          "group": "inline"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "ignorePanel.ignoredFiles",
          "name": "Ignored Files",
          "icon": "resources/ignored-files.svg"
        }
      ]
    }
  },
  "scripts": {
    "lint": "node --check src/extension.js"
  },
  "devDependencies": {}
}
